BOT_TOKEN=123456:replace-me
OUTPUT_WIDTH=640
OUTPUT_HEIGHT=360
STICKER_SIZE=220
OUTPUT_FPS=30
MAX_OUTPUT_WIDTH=1920
MAX_OUTPUT_HEIGHT=1080
MAX_OUTPUT_PIXELS=2073600
MAX_OUTPUT_FPS=60
DEFAULT_OUTPUT_FORMAT=gif
STATIC_SECONDS=2.0
DEFAULT_BACKGROUND=dark
MAX_CUSTOM_EMOJI_RENDER_ITEMS=5
MAX_PACK_RENDER_ITEMS=3
MENU_ASSET_WIDTH=640
MENU_ASSET_HEIGHT=360
# macOS
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Linux (Chromium via apt/dnf)
# CHROME_PATH=/usr/bin/chromium-browser

# Windows (Git Bash / WSL)
# CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# Docker — already set by Dockerfile, leave commented out:
# CHROME_PATH=/usr/bin/chromium
MAX_GLOBAL_RENDERS=2
PER_USER_WINDOW_JOBS=2
PER_USER_WINDOW_SECONDS=60
PER_USER_MIN_GAP_SECONDS=5
SPAM_EVENTS_BEFORE_BAN=6
SPAM_WINDOW_SECONDS=60
BAN_SECONDS=3600
MAX_SOURCE_BYTES=10485760
MAX_OUTPUT_BYTES=47185920
RENDER_TIMEOUT_SECONDS=75
RUNS_RETENTION_SECONDS=43200
LOG_CHAT_ID=
LOG_NEW_USERS=true
LOG_RENDER_REQUESTS=true
LOG_RENDER_SOURCE_PREVIEW=true
ADMIN_USER_IDS=
ALLOW_LOG_CHAT_ADMINS=true
BROADCAST_DELAY_SECONDS=0.05
BROADCAST_DRAFT_TTL_SECONDS=1800
SYNC_BOT_PROFILE_ON_STARTUP=false
WATERMARK_ENABLED=false
WATERMARK_TEXT=StickerLoop
WATERMARK_OPACITY=0.16
WATERMARK_FONT_SIZE=13
WATERMARK_MARGIN=12
WATERMARK_POSITION=bottom_left
WATERMARK_COLOR=white
WATERMARK_SHADOW_COLOR=black
WATERMARK_SHADOW_OPACITY=0.12
# WEBHOOK_URL=https://your-domain.com  # Uncomment for webhook mode (no polling)
# WEBHOOK_PORT=8000
# WEBHOOK_PATH=/webhook
